VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Books API key (free — https://console.cloud.google.com/apis/library/books.googleapis.com)
# Without this, only Open Library is searched. With it, Google Books is searched as a fallback.
# VITE_GOOGLE_BOOKS_API_KEY=your_google_books_api_key

# WARNING: DATABASE_URL gives full database access, bypassing all RLS policies.
# Only add this if you need CLI tools to run migrations directly.
# Find it in: Supabase Dashboard → Project Settings → Database → Connection string
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
